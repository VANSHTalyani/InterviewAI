# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost/video_analysis_db
TEST_DATABASE_URL=postgresql://username:password@localhost/test_video_analysis_db

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage Configuration
STORAGE_TYPE=local  # Options: local, firebase, supabase
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=500000000  # 500MB in bytes

# Firebase Configuration (if using Firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket-name
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Supabase Configuration (if using Supabase)
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key
SUPABASE_BUCKET=video-uploads

# AI Service API Keys
OPENAI_API_KEY=your-openai-api-key
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Video Processing Configuration
FFMPEG_PATH=/usr/bin/ffmpeg
FRAME_EXTRACTION_INTERVAL=5  # seconds
AUDIO_SAMPLE_RATE=16000
VIDEO_MAX_DURATION=1800  # 30 minutes in seconds

# Analysis Configuration
ENABLE_TRANSCRIPTION=True
ENABLE_TONE_ANALYSIS=True
ENABLE_BODY_LANGUAGE=True
ENABLE_EMOTION_DETECTION=True
ENABLE_CLARITY_ANALYSIS=True

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
SENTRY_DSN=your-sentry-dsn

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
